`timescale 1ns / 1ps
module ALU_tb;
    reg  [7:0] A;
    reg  [7:0] B;
    reg  [2:0] Sel;
    wire [7:0] Y;
    ALU uut (
        .A   (A),
        .B   (B),
        .Sel (Sel),
        .Y   (Y)
    );
    initial begin
        A = 8'd5;B = 8'd2;Sel = 3'b000; #100;
        A = 8'd5;B = 8'd2;Sel = 3'b001; #100;
        A = 8'd5;B = 8'd2;Sel = 3'b010; #100;
        A = 8'd5;B = 8'd2;Sel = 3'b011; #100;
        A = 8'd5;Sel = 3'b100; #100;
        B = 8'd2;Sel = 3'b101; #100;
    end
endmodule
